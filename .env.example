# ── Admin ────────────────────────────────────────────────────────────────────
# Your WhatsApp number (international format, no + or spaces)
ADMIN_PHONE=50766xxxxxx

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Waha (WhatsApp gateway) ───────────────────────────────────────────────────
WAHA_URL=http://waha:3000
WAHA_SESSION=default
WAHA_API_KEY=                        # leave empty if not using waha auth
WAHA_BOT_PHONE=50766xxxxxx           # the number linked to waha

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://schoolbot:schoolbot@postgres:5432/schoolbot

# ── Encryption ────────────────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# NEVER commit this key. Back it up separately.
FERNET_KEY=

# ── Scheduler ─────────────────────────────────────────────────────────────────
TIMEZONE=America/Panama
SYNC_TIME=18:20          # daily assignment sync (HH:MM)
SUMMARY_DAY=thursday     # day to send weekly summary
SUMMARY_TIME=18:30       # time to send weekly summary (HH:MM)
REMINDER_TIME=07:00      # daily morning reminder (HH:MM, Mon-Fri)
